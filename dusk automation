<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dusk Automation — AI Chat & Missed Call Solutions for Australian Small Business</title>
  <meta name="description" content="Dusk Automation helps Australian small businesses capture every lead with AI-powered live website chat and missed call auto-reply. Set up in 24 hours. Flat monthly pricing."/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --black:      #0c0a0a;
      --surface:    #130e0e;
      --surface2:   #1c1414;
      --surface3:   #251a1a;
      --crimson:    #8b1a1a;
      --maroon:     #6b1212;
      --maroon-lt:  #a82424;
      --ember:      #c45c1a;
      --ember-lt:   #e0782a;
      --ash:        #4a3535;
      --text:       #f0e8e0;
      --text-muted: #9a8070;
      --text-dim:   #5a4040;
      --border:     rgba(139,26,26,0.18);
      --border-lt:  rgba(196,92,26,0.22);
      --glow-red:   rgba(139,26,26,0.35);
      --glow-ember: rgba(196,92,26,0.25);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: var(--text);
      font-family: 'Outfit', sans-serif;
      font-size: 16px;
      line-height: 1.65;
      overflow-x: hidden;
    }

    /* ─── NOISE TEXTURE OVERLAY ─── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.6;
    }

    /* ─── TYPOGRAPHY ─── */
    h1, h2, h3, .display {
      font-family: 'Cormorant Garamond', serif;
      letter-spacing: -0.02em;
    }

    /* ─── NAVIGATION ─── */
    nav {
      position: sticky;
      top: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 64px;
      height: 68px;
      background: rgba(12,10,10,0.88);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
    }

    .logo-icon {
      width: 38px;
      height: 38px;
      position: relative;
      flex-shrink: 0;
    }

    .logo-wordmark {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--text);
      letter-spacing: 0.04em;
    }

    .logo-wordmark span {
      color: var(--ember-lt);
    }

    nav ul {
      display: flex;
      list-style: none;
      gap: 40px;
    }

    nav ul a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 14px;
      font-weight: 400;
      letter-spacing: 0.02em;
      transition: color 0.2s;
    }

    nav ul a:hover { color: var(--text); }

    .nav-cta {
      background: var(--crimson);
      color: var(--text) !important;
      padding: 10px 24px;
      border-radius: 6px;
      font-weight: 500 !important;
      font-size: 14px !important;
      transition: background 0.2s, transform 0.15s !important;
    }

    .nav-cta:hover {
      background: var(--maroon-lt) !important;
      transform: translateY(-1px);
    }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      min-height: 92vh;
      display: flex;
      align-items: center;
      padding: 100px 64px 80px;
      overflow: hidden;
    }

    /* Dusk gradient background */
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 70% 40%, rgba(139,26,26,0.22) 0%, transparent 70%),
        radial-gradient(ellipse 40% 30% at 85% 60%, rgba(196,92,26,0.12) 0%, transparent 60%),
        radial-gradient(ellipse 30% 40% at 20% 80%, rgba(107,18,18,0.15) 0%, transparent 60%);
      pointer-events: none;
    }

    /* Horizon line effect */
    .hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--crimson), var(--ember), var(--crimson), transparent);
      opacity: 0.5;
    }

    .hero-content {
      position: relative;
      z-index: 1;
      max-width: 680px;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ember-lt);
      margin-bottom: 28px;
    }

    .hero-eyebrow::before {
      content: '';
      display: block;
      width: 28px;
      height: 1px;
      background: var(--ember-lt);
    }

    h1 {
      font-size: 82px;
      font-weight: 700;
      line-height: 0.95;
      margin-bottom: 32px;
      color: var(--text);
    }

    h1 em {
      font-style: italic;
      color: var(--ember-lt);
    }

    .hero-sub {
      font-size: 18px;
      font-weight: 300;
      color: var(--text-muted);
      line-height: 1.7;
      max-width: 480px;
      margin-bottom: 52px;
    }

    .hero-actions {
      display: flex;
      gap: 20px;
      align-items: center;
      margin-bottom: 72px;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--crimson);
      color: var(--text);
      padding: 16px 32px;
      border-radius: 6px;
      font-size: 15px;
      font-weight: 500;
      text-decoration: none;
      letter-spacing: 0.02em;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      border: 1px solid var(--maroon-lt);
    }

    .btn-primary:hover {
      background: var(--maroon-lt);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px var(--glow-red);
    }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--text-muted);
      text-decoration: none;
      font-size: 14px;
      font-weight: 400;
      transition: color 0.2s;
      border: 1px solid var(--border);
      padding: 15px 28px;
      border-radius: 6px;
    }

    .btn-ghost:hover { color: var(--text); border-color: var(--ash); }

    .hero-stats {
      display: flex;
      gap: 48px;
    }

    .stat-item {}
    .stat-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 40px;
      font-weight: 700;
      color: var(--text);
      line-height: 1;
      margin-bottom: 4px;
    }

    .stat-num span { color: var(--ember-lt); }
    .stat-label { font-size: 13px; color: var(--text-dim); font-weight: 300; }

    /* Floating visual right side */
    .hero-visual {
      position: absolute;
      right: 64px;
      top: 50%;
      transform: translateY(-50%);
      width: 420px;
      z-index: 1;
    }

    .chat-window {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 32px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(139,26,26,0.1);
    }

    .chat-header {
      background: var(--surface3);
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid var(--border);
    }

    .chat-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--crimson), var(--ember));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      flex-shrink: 0;
    }

    .chat-header-info h4 {
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      font-weight: 500;
      color: var(--text);
    }

    .chat-header-info p {
      font-size: 11px;
      color: var(--ember-lt);
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .online-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--ember-lt);
      display: inline-block;
      animation: blink 2s infinite;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    .chat-body {
      padding: 20px 18px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      min-height: 240px;
    }

    .msg-row {
      display: flex;
      gap: 8px;
      align-items: flex-end;
    }

    .msg-row.right { flex-direction: row-reverse; }

    .msg-avatar {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      flex-shrink: 0;
      font-size: 9px;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .msg-avatar.bot { background: linear-gradient(135deg, var(--crimson), var(--ember)); color: var(--text); }
    .msg-avatar.user { background: var(--surface3); color: var(--text-muted); border: 1px solid var(--border); }

    .bubble {
      padding: 10px 14px;
      border-radius: 10px;
      font-size: 13px;
      line-height: 1.5;
      max-width: 260px;
    }

    .bubble.bot {
      background: var(--surface3);
      border: 1px solid var(--border);
      color: var(--text);
      border-bottom-left-radius: 3px;
    }

    .bubble.user {
      background: var(--crimson);
      color: var(--text);
      border-bottom-right-radius: 3px;
    }

    .typing-indicator {
      display: flex;
      gap: 4px;
      align-items: center;
      padding: 10px 14px;
      background: var(--surface3);
      border: 1px solid var(--border);
      border-radius: 10px;
      border-bottom-left-radius: 3px;
      width: fit-content;
    }

    .td { width: 5px; height: 5px; border-radius: 50%; background: var(--ember-lt); animation: tdot 1.4s infinite; }
    .td:nth-child(2) { animation-delay: 0.2s; }
    .td:nth-child(3) { animation-delay: 0.4s; }

    @keyframes tdot {
      0%, 100% { transform: translateY(0); opacity: 0.4; }
      50% { transform: translateY(-4px); opacity: 1; }
    }

    .chat-input-bar {
      padding: 14px 18px;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .chat-input-bar input {
      flex: 1;
      background: var(--surface3);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 9px 14px;
      font-size: 13px;
      color: var(--text-muted);
      font-family: 'Outfit', sans-serif;
      outline: none;
    }

    .chat-send {
      width: 34px;
      height: 34px;
      background: var(--crimson);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      flex-shrink: 0;
      transition: background 0.2s;
    }

    .chat-send:hover { background: var(--maroon-lt); }

    /* SMS preview card */
    .sms-card {
      margin-top: 16px;
      background: var(--surface2);
      border: 1px solid var(--border-lt);
      border-radius: 14px;
      padding: 16px 18px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }

    .sms-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--ember-lt);
      font-weight: 500;
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .sms-bubble {
      background: var(--surface3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 14px;
      font-size: 13px;
      color: var(--text);
      line-height: 1.55;
    }

    .sms-bubble strong { color: var(--ember-lt); font-weight: 500; }

    .sms-meta {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 11px;
      color: var(--text-dim);
    }

    /* ─── SHARED SECTION STYLES ─── */
    section { position: relative; }

    .container {
      max-width: 1140px;
      margin: 0 auto;
      padding: 0 64px;
    }

    .section-label {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ember-lt);
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
    }

    .section-label::before {
      content: '';
      display: block;
      width: 24px;
      height: 1px;
      background: var(--ember-lt);
    }

    h2 {
      font-size: 54px;
      font-weight: 700;
      line-height: 1.0;
      color: var(--text);
      margin-bottom: 16px;
    }

    .section-sub {
      font-size: 17px;
      font-weight: 300;
      color: var(--text-muted);
      max-width: 500px;
      line-height: 1.7;
      margin-bottom: 60px;
    }

    /* ─── LOGO BAR ─── */
    .logo-bar {
      padding: 40px 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .logo-bar-inner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
      padding: 0 64px;
    }

    .logo-bar-label {
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-dim);
      font-weight: 400;
      margin-right: 12px;
    }

    .client-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--ash);
      letter-spacing: 0.06em;
      padding: 6px 20px;
      border: 1px solid rgba(74,53,53,0.4);
      border-radius: 4px;
      transition: color 0.2s, border-color 0.2s;
    }

    .client-name:hover { color: var(--text-muted); border-color: var(--ash); }

    /* ─── SERVICES ─── */
    .services-section {
      padding: 110px 0;
    }

    .services-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
    }

    .service-card {
      background: var(--surface);
      padding: 52px 48px;
      position: relative;
      transition: background 0.3s;
    }

    .service-card:hover { background: var(--surface2); }

    .service-card:nth-child(1) { border-right: 1px solid var(--border); }

    .service-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 72px;
      font-weight: 700;
      color: rgba(139,26,26,0.12);
      line-height: 1;
      margin-bottom: 24px;
    }

    .service-icon-wrap {
      width: 52px;
      height: 52px;
      background: rgba(139,26,26,0.12);
      border: 1px solid rgba(139,26,26,0.25);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 24px;
    }

    .service-card h3 {
      font-size: 30px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 16px;
      line-height: 1.15;
    }

    .service-card p {
      font-size: 15px;
      font-weight: 300;
      color: var(--text-muted);
      line-height: 1.7;
      margin-bottom: 28px;
    }

    .service-features {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .service-features li {
      font-size: 14px;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 300;
    }

    .service-features li::before {
      content: '';
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--ember-lt);
      flex-shrink: 0;
    }

    .service-tag {
      display: inline-block;
      margin-top: 28px;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ember-lt);
      border: 1px solid rgba(196,92,26,0.25);
      border-radius: 4px;
      padding: 5px 12px;
      font-weight: 500;
    }

    /* ─── HOW IT WORKS ─── */
    .how-section {
      padding: 110px 0;
      background: var(--surface);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .steps-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
    }

    .step-card {
      padding: 44px 36px;
      position: relative;
      border-right: 1px solid var(--border);
      background: var(--surface);
      transition: background 0.3s;
    }

    .step-card:last-child { border-right: none; }
    .step-card:hover { background: var(--surface2); }

    .step-arrow {
      position: absolute;
      top: 50%;
      right: -14px;
      transform: translateY(-50%);
      z-index: 2;
      background: var(--surface3);
      border: 1px solid var(--border);
      border-radius: 50%;
      width: 26px;
      height: 26px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .step-card:last-child .step-arrow { display: none; }

    .step-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 56px;
      font-weight: 700;
      color: rgba(196,92,26,0.14);
      line-height: 1;
      margin-bottom: 16px;
    }

    .step-card h4 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 20px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 12px;
      line-height: 1.2;
    }

    .step-card p {
      font-size: 13px;
      font-weight: 300;
      color: var(--text-muted);
      line-height: 1.65;
    }

    /* ─── RESULTS / SOCIAL PROOF ─── */
    .results-section {
      padding: 110px 0;
    }

    .results-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 1fr;
      gap: 2px;
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 64px;
    }

    .result-card {
      background: var(--surface);
      padding: 44px 36px;
      border-right: 1px solid var(--border);
      text-align: center;
      transition: background 0.3s;
    }

    .result-card:last-child { border-right: none; }
    .result-card:hover { background: var(--surface2); }

    .result-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 56px;
      font-weight: 700;
      line-height: 1;
      margin-bottom: 8px;
    }

    .result-num.crimson { color: var(--maroon-lt); }
    .result-num.ember { color: var(--ember-lt); }
    .result-label { font-size: 13px; color: var(--text-dim); font-weight: 300; }

    .testimonials-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 20px;
    }

    .testimonial {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 36px;
      position: relative;
      transition: border-color 0.25s;
    }

    .testimonial:hover { border-color: rgba(139,26,26,0.35); }

    .testimonial::before {
      content: '"';
      font-family: 'Cormorant Garamond', serif;
      font-size: 80px;
      color: rgba(196,92,26,0.12);
      position: absolute;
      top: 16px;
      left: 28px;
      line-height: 1;
    }

    .testimonial p {
      font-size: 15px;
      font-weight: 300;
      color: var(--text-muted);
      line-height: 1.7;
      margin-bottom: 24px;
      padding-top: 16px;
    }

    .testimonial-author {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .author-avatar {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--crimson), var(--ember));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      flex-shrink: 0;
    }

    .author-name {
      font-size: 14px;
      font-weight: 500;
      color: var(--text);
    }

    .author-role {
      font-size: 12px;
      color: var(--text-dim);
      font-weight: 300;
    }

    /* ─── PRICING ─── */
    .pricing-section {
      padding: 110px 0;
      background: var(--surface);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 20px;
    }

    .price-card {
      background: var(--black);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 44px 40px;
      position: relative;
      transition: border-color 0.25s, transform 0.2s;
    }

    .price-card:hover {
      border-color: var(--ash);
      transform: translateY(-3px);
    }

    .price-card.featured {
