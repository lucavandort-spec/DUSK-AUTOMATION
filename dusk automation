    .form-field select { appearance: none; cursor: pointer; }

    .form-field textarea {
      resize: vertical;
      min-height: 100px;
    }

    .form-submit {
      background: var(--crimson);
      color: var(--text);
      border: none;
      padding: 14px 32px;
      border-radius: 7px;
      font-size: 15px;
      font-weight: 500;
      font-family: 'Outfit', sans-serif;
      cursor: pointer;
      transition: background 0.2s, box-shadow 0.2s;
      align-self: flex-start;
      letter-spacing: 0.02em;
    }

    .form-submit:hover {
      background: var(--maroon-lt);
      box-shadow: 0 6px 24px var(--glow-red);
    }

    /* ─── SCROLL FADE IN ─── */
    .fade-up {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .fade-up.visible {
      opacity: 1;
      transform: none;
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 1024px) {
      nav { padding: 0 32px; }
      nav ul { display: none; }
      .hero { padding: 80px 32px 60px; min-height: auto; }
